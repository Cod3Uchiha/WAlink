# WhatsApp number including country code, without a plus sign.
BOT_PHONE_NUMBER=263700000000

# Free Cod3Uchiha API endpoint used by the bot.
COD3UCHIHA_AI_ENDPOINT=https://cod3uchiha.com/ai/copilot

# Local directory used to persist the paired WhatsApp session.
WALINK_AUTH_DIRECTORY=walink_bot_auth

# Optional request and logging settings.
AI_TIMEOUT_MS=45000
LOG_LEVEL=info
